{
  "name": "chakra-react-table-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "storybook": "turbo run storybook --filter=@chakra-react-table/storybook",
    "build:storybook:turbo": "turbo run build-storybook --filter=@chakra-react-table/storybook",
    "dev:docs": "pnpm -C apps/docs dev",
    "build:docs": "pnpm -C apps/docs build",
    "dev:storybook": "pnpm -C apps/storybook storybook",
    "build:storybook": "pnpm -C apps/storybook build-storybook",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "release:local": "bash ./scripts/release-local.sh",
    "release:local:force": "NO_GIT_CHECKS=1 bash ./scripts/release-local.sh",
    "release:auto": "bash ./scripts/release-auto.sh",
    "release:auto:minor": "bash ./scripts/release-auto.sh --bump minor",
    "release:auto:major": "bash ./scripts/release-auto.sh --bump major"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
